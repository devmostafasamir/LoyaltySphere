# ============================================
# LoyaltySphere - Environment Variables
# ============================================
# Copy this file to .env and update with your values
# Usage: docker compose -f docker-compose.prod.yml --env-file .env up -d
# ============================================

# Database Configuration
POSTGRES_PASSWORD=your_secure_postgres_password_here

# RabbitMQ Configuration
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=your_secure_rabbitmq_password_here

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here

# Docker Hub Configuration (for CI/CD)
DOCKER_USERNAME=msaid356
DOCKER_PASSWORD=your_docker_hub_token_here

# Application Configuration
ASPNETCORE_ENVIRONMENT=Production
NODE_ENV=production

# ============================================
# SECURITY NOTES:
# ============================================
# 1. Never commit .env file to version control
# 2. Use strong passwords (minimum 16 characters)
# 3. Rotate passwords regularly
# 4. Use Docker secrets in production
# 5. Enable SSL/TLS for all services
# ============================================
