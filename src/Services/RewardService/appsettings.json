  "Auth": {
    "Authority": "https://your-identity-provider.com",
    "Audience": "loyaltysphere-api",
    "RequireHttpsMetadata": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "http://loyaltysphere.runasp.net",
      "https://loyaltysphere.runasp.net"
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "App_Data/logs/reward-service-.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "LoyaltySphere.RewardService"
    }
  },
  "AllowedHosts": "*",
  "HealthChecks": {
    "Enabled": true,
    "EvaluationTimeInSeconds": 30
  },
  "Cache": {
    "DefaultExpirationMinutes": 60,
    "RewardRulesExpirationMinutes": 120,
    "CampaignsExpirationMinutes": 60
  },
  "Resilience": {
    "RetryCount": 3,
    "RetryDelaySeconds": 2,
    "CircuitBreakerThreshold": 5,
    "CircuitBreakerDurationSeconds": 30
  },
  "Outbox": {
    "ProcessingIntervalSeconds": 10,
    "BatchSize": 100,
    "MaxRetries": 3
  },
  "SignalR": {
    "KeepAliveIntervalSeconds": 15,
    "ClientTimeoutSeconds": 30
  },
  "Tenants": {
