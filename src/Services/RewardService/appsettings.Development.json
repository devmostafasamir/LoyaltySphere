{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=loyaltysphere_dev;Username=postgres;Password=postgres;Include Error Detail=true",
    "Redis": "localhost:6379,abortConnect=false",
    "RabbitMQ": "amqp://guest:guest@localhost:5672"
  },
  "Auth": {
    "Authority": "https://localhost:5001",
    "Audience": "loyaltysphere-api",
